class RawInput:
    """Non-blocking keyboard reader using cbreak terminal mode.

    Uses cbreak (not raw) so that terminal output processing (newlines,
    carriage returns, cursor movement) still works correctly with Rich.
    """

    def __init__(self):
        self._fd = sys.stdin.fileno()
        self._old_settings = None

    def __enter__(self):
        self._old_settings = termios.tcgetattr(self._fd)
        tty.setcbreak(self._fd)
        return self

    def __exit__(self, *_):
        if self._old_settings:
            termios.tcsetattr(self._fd, termios.TCSADRAIN, self._old_settings)

    def read_key(self) -> str | None:
        """Read a keypress if available. Returns None if no key is pending.

        Uses os.read() on the raw file descriptor to avoid Python-level
        buffering conflicts with cbreak mode and Rich's Live display.
        """
        if not select.select([self._fd], [], [], 0)[0]:
            return None
        ch = os.read(self._fd, 1).decode("utf-8", errors="ignore")
        if ch == "\x1b":
            # Escape sequence (arrow keys, etc.)
            if select.select([self._fd], [], [], 0.05)[0]:
                ch += os.read(self._fd, 1).decode("utf-8", errors="ignore")
                if select.select([self._fd], [], [], 0.05)[0]:
                    ch += os.read(self._fd, 1).decode("utf-8", errors="ignore")
        return ch


