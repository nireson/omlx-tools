# ---------------------------------------------------------------------------
# System stats (macOS-only)
# ---------------------------------------------------------------------------

def get_system_stats() -> dict[str, Any]:
    """Collect CPU, GPU, and memory stats from macOS APIs."""
    stats: dict[str, Any] = {}

    try:
        r = subprocess.run(
            ["top", "-l", "1", "-n", "0", "-s", "0"],
            capture_output=True, text=True, timeout=3,
        )
        for line in r.stdout.split("\n"):
            if "CPU usage" in line:
                parts = line.split()
                for i, p in enumerate(parts):
                    if p == "user,":
                        stats["cpu_user"] = float(parts[i - 1].rstrip("%"))
                    elif p == "sys,":
                        stats["cpu_sys"] = float(parts[i - 1].rstrip("%"))
                    elif p == "idle":
                        stats["cpu_idle"] = float(parts[i - 1].rstrip("%"))
                stats["cpu_used"] = round(
                    stats.get("cpu_user", 0) + stats.get("cpu_sys", 0), 1
                )
                break
    except Exception:
        pass

    try:
        r = subprocess.run(
            ["ioreg", "-r", "-d", "1", "-c", "AGXAccelerator", "-a"],
            capture_output=True, timeout=3,
        )
        data = plistlib.loads(r.stdout)
        for item in data:
            ps = item.get("PerformanceStatistics", {})
            if ps:
                stats["gpu_util"] = ps.get("Device Utilization %", 0)
                stats["gpu_alloc"] = ps.get("Alloc system memory", 0)
                break
    except Exception:
        pass

    try:
        page_size = os.sysconf("SC_PAGE_SIZE")
        r = subprocess.run(["vm_stat"], capture_output=True, text=True, timeout=3)
        pages: dict[str, int] = {}
        for line in r.stdout.split("\n"):
            for key in ("free", "active", "inactive", "wired", "compressor"):
                if key in line.lower() and ":" in line:
                    val = line.split(":")[1].strip().rstrip(".")
                    pages[key] = int(val)
        used_pages = (
            pages.get("active", 0) + pages.get("wired", 0) + pages.get("compressor", 0)
        )
        r2 = subprocess.run(
            ["sysctl", "-n", "hw.memsize"], capture_output=True, text=True, timeout=3,
        )
        total_bytes = int(r2.stdout.strip())
        used_bytes = used_pages * page_size
        stats["ram_total"] = total_bytes
        stats["ram_used"] = used_bytes
        stats["ram_pct"] = round(used_bytes / total_bytes * 100, 1) if total_bytes else 0
    except Exception:
        pass

    return stats


def get_recent_activity(model_name: str, max_lines: int = 15) -> list[str]:
    """Parse the oMLX log for recent activity related to a specific model.

    Returns a list of formatted log lines (most recent last).
    """
    log_path = Path(os.environ.get("OMLX_LOG", "/opt/homebrew/var/log/omlx.log"))
    if not log_path.exists():
        return []

    lines: list[str] = []
    try:
        # Read last chunk of log (avoid reading entire file)
        with open(log_path, "rb") as f:
            # Seek to last 200KB
            f.seek(0, 2)
            size = f.tell()
            f.seek(max(0, size - 200_000))
            raw = f.read().decode("utf-8", errors="ignore")

        for line in raw.split("\n"):
            if model_name not in line:
                continue
            # Filter to interesting log lines
            if any(kw in line for kw in (
                "Chat completion:",
                "completion request received",
                "Loading model",
                "Loaded model",
                "paged cache hit",
                "tokens in",
            )):
                # Extract timestamp and message
                parts = line.split(" - ", 2)
                if len(parts) >= 3:
                    ts = parts[0].split(",")[0]  # drop milliseconds
                    # Shorten timestamp to HH:MM:SS
                    if " " in ts:
                        ts = ts.split(" ")[-1]
                    msg = parts[2].strip()
                    # Clean up common prefixes
                    msg = msg.replace("Chat completion request received: ", "req: ")
                    msg = msg.replace("Chat completion: ", "done: ")
                    msg = msg.replace(f"model={model_name}, ", "")
                    lines.append(f"[dim]{ts}[/] {msg}")
    except Exception:
        pass

    return lines[-max_lines:]


class StatsCollector:
    """Collects system stats in a background thread to avoid blocking the UI.

    The main loop reads the latest stats via ``latest`` without ever waiting
    for ``top``, ``ioreg``, or ``vm_stat`` to finish.
    """

    def __init__(self, interval: float = 2.0):
        self._interval = interval
        self._stats: dict[str, Any] = {}
        self._lock = threading.Lock()
        self._stop = threading.Event()
        self._thread = threading.Thread(target=self._run, daemon=True)

    def start(self) -> None:
        self._thread.start()

    def stop(self) -> None:
        self._stop.set()

    @property
    def latest(self) -> dict[str, Any]:
        with self._lock:
            return dict(self._stats)

    def _run(self) -> None:
        while not self._stop.is_set():
            stats = get_system_stats()
            with self._lock:
                self._stats = stats
            self._stop.wait(self._interval)


def load_model_stats() -> dict[str, Any]:
    """Load per-model performance stats from oMLX's persisted stats file."""
    stats_path = Path(os.environ.get("OMLX_HOME", Path.home() / ".omlx")) / "stats.json"
    try:
        with open(stats_path) as f:
            data = json.load(f)
        return data.get("per_model", {})
    except Exception:
        return {}


