# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------

def fetch_json(url: str, timeout: float = 2.0) -> dict | None:
    """Fetch JSON from *url*, returning ``None`` on any failure."""
    try:
        with urllib.request.urlopen(url, timeout=timeout) as r:
            return json.loads(r.read())
    except Exception:
        return None


def fmt_bytes(n: int) -> str:
    """Format a byte count as a human-readable string."""
    if n >= 1 << 30:
        return f"{n / (1 << 30):.1f} GB"
    if n >= 1 << 20:
        return f"{n / (1 << 20):.0f} MB"
    return f"{n} B"


def fmt_duration(seconds: float) -> str:
    """Format a duration in seconds as a compact human-readable string."""
    seconds = max(0, seconds)
    d = timedelta(seconds=int(seconds))
    days = d.days
    hours, rem = divmod(d.seconds, 3600)
    mins, secs = divmod(rem, 60)
    if days > 0:
        return f"{days}d {hours}h {mins}m"
    if hours > 0:
        return f"{hours}h {mins}m {secs}s"
    return f"{mins}m {secs}s"


def fmt_tps(tps: float) -> str:
    """Format tokens-per-second, returning ``-`` for zero."""
    if tps == 0:
        return "-"
    return f"{tps:.1f}"


def make_bar(pct: float, width: int = 20, thresholds: tuple = (60, 85)) -> Text:
    """Render a progress bar as a Rich ``Text`` object."""
    pct = max(0.0, min(100.0, pct))
    filled = int(width * pct / 100)
    color = "green" if pct < thresholds[0] else "yellow" if pct < thresholds[1] else "red"
    bar = Text()
    bar.append("[")
    bar.append("█" * filled, style=color)
    bar.append("░" * (width - filled), style="bright_black")
    bar.append(f"] {pct:.0f}%")
    return bar


