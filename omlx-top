def build_detail_view(
    status: dict,
    model: dict,
    model_perf: dict,
    sys_stats: dict[str, Any],
) -> Layout:
    """Build a detail view for a single model."""
    name = model.get("id", "?")
    is_loaded = model.get("loaded", False)
    loading = model.get("is_loading", False)
    pinned = model.get("pinned", False)

    # Status
    if loading:
        status_str = "Loading..."
        status_style = "bold yellow"
    elif is_loaded and pinned:
        status_str = "Loaded (pinned)"
        status_style = "bold cyan"
    elif is_loaded:
        status_str = "Loaded"
        status_style = "bold green"
    else:
        status_str = "Idle (not loaded)"
        status_style = "dim"

    # Info table
    info = Table(show_header=False, box=None, padding=(0, 2), expand=True)
    info.add_column("Key", style="dim", width=20)
    info.add_column("Value")

    info.add_row("Status", Text(status_str, style=status_style))
    info.add_row("Architecture", model.get("config_model_type", "?"))
    info.add_row("Engine", model.get("engine_type", "?"))
    info.add_row("Type", model.get("model_type", "?"))
    info.add_row("Estimated Size", fmt_bytes(model.get("estimated_size", 0)))
    info.add_row("Pinned", "Yes" if pinned else "No")

    last = model.get("last_access")
    if isinstance(last, (int, float)):
        info.add_row("Last Access", fmt_duration(max(0, time.time() - last)) + " ago")
    else:
        info.add_row("Last Access", "-")

    # Performance stats
    perf = model_perf.get(name, {})
    reqs = perf.get("requests", 0)
    pt = perf.get("prompt_tokens", 0)
    ct = perf.get("completion_tokens", 0)
    cached = perf.get("cached_tokens", 0)
    pd = perf.get("prefill_duration", 0)
    gd = perf.get("generation_duration", 0)

    prefill_tps = (pt - cached) / pd if pd > 0 else 0
    gen_tps = ct / gd if gd > 0 else 0

    info.add_row("", "")  # spacer
    info.add_row(Text("Performance", style="bold bright_white"), "")
    info.add_row("Requests", str(reqs) if reqs else "-")
    info.add_row("Prompt Tokens", f"{pt:,}" if pt else "-")
    info.add_row("Completion Tokens", f"{ct:,}" if ct else "-")
    info.add_row("Cached Tokens", f"{cached:,}" if cached else "-")
    if pt > 0 and cached > 0:
        info.add_row("Cache Hit Rate", f"{cached / pt * 100:.1f}%")
    info.add_row("Avg Prefill", f"{prefill_tps:.1f} tok/s" if prefill_tps else "-")
    info.add_row("Avg Generation", f"{gen_tps:.1f} tok/s" if gen_tps else "-")
    if pd > 0:
        info.add_row("Total Prefill Time", f"{pd:.1f}s")
    if gd > 0:
        info.add_row("Total Gen Time", f"{gd:.1f}s")
    if reqs > 0 and ct > 0:
        avg_tokens = ct / reqs
        info.add_row("Avg Tokens/Request", f"{avg_tokens:.0f}")

    # Activity log from oMLX log file
    activity = get_recent_activity(name)
    activity_text = Text()
    if activity:
        for line in activity:
            activity_text.append_text(Text.from_markup(line + "\n"))
    else:
        activity_text.append("No recent activity", style="dim")

    layout = Layout()
    layout.split_column(
        Layout(name="header", size=10),
        Layout(name="detail"),
        Layout(name="activity"),
    )
    layout["header"].update(build_header(status, sys_stats))
    layout["detail"].update(
        Panel(
            info,
            title=f"[bold cyan]{name}[/]",
            border_style="cyan",
            padding=(0, 2),
        )
    )
    layout["activity"].update(
        Panel(
            activity_text,
            title="[bold]Recent Activity[/]",
            subtitle="[dim]esc back[/]",
            subtitle_align="left",
            border_style="bright_black",
            padding=(0, 1),
        )
    )
    return layout


# ---------------------------------------------------------------------------
# Display dispatcher
# ---------------------------------------------------------------------------

def build_display(
    base_url: str,
    sys_stats: dict[str, Any],
    selected: int = 0,
    detail_model: str | None = None,
) -> tuple[Union[Layout, Panel], list[dict]]:
    """Build the display and return (renderable, model_list).

    Returns the model list so the caller can track selection bounds.
    """
    status = fetch_json(f"{base_url}/api/status")
    models_data = fetch_json(f"{base_url}/v1/models/status")
    model_perf = load_model_stats()
    model_list = get_model_list(models_data)

    if not status:
        panel = Panel(
            Text(
                f"Cannot connect to oMLX server at {base_url}",
                style="bold red",
                justify="center",
            ),
            title="omlx-top",
            border_style="red",
        )
        return panel, []

    if detail_model is not None:
        # Find the model in the list
        model = next((m for m in model_list if m.get("id") == detail_model), None)
        if model:
            return build_detail_view(status, model, model_perf, sys_stats), model_list
        # Model not found — fall back to main view
        detail_model = None

    return build_main_view(status, model_list, model_perf, sys_stats, selected), model_list


# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------

def main() -> None:
    """Entry point."""
    if sys.platform != "darwin":
        print("omlx-top requires macOS (Apple Silicon)", file=sys.stderr)
        sys.exit(1)

    parser = argparse.ArgumentParser(
        description="omlx-top — live TUI dashboard for oMLX server",
    )
    parser.add_argument(
        "--url",
        default="http://localhost:11435",
        help="oMLX server URL (default: %(default)s)",
    )
    parser.add_argument(
        "-n", "--interval",
        type=float,
        default=2.0,
        help="Refresh interval in seconds (default: %(default)s)",
    )
    args = parser.parse_args()

    console = Console()
    base_url = args.url.rstrip("/")

    selected = 0
    detail_model: str | None = None
    model_list: list[dict] = []

    # Collect system stats in a background thread so the UI never blocks.
    collector = StatsCollector(interval=args.interval)
    collector.start()

    raw_input = RawInput()
    with raw_input:
        try:
            display, model_list = build_display(
                base_url, collector.latest, selected, detail_model,
            )
            with Live(display, console=console, refresh_per_second=4, screen=True) as live:
                last_refresh = time.time()
                while True:
                    # Poll keys at ~50 Hz for responsive input
                    time.sleep(0.02)

                    key = raw_input.read_key()
                    needs_update = False

                    if key == KEY_CTRL_C:
                        break
                    elif key in (KEY_Q, KEY_ESC) and detail_model is not None:
                        detail_model = None
                        needs_update = True
                    elif key in (KEY_Q, KEY_ESC) and detail_model is None:
                        break
                    elif key in (KEY_UP, KEY_K) and detail_model is None:
                        if model_list:
                            selected = (selected - 1) % len(model_list)
                            needs_update = True
                    elif key in (KEY_DOWN, KEY_J) and detail_model is None:
                        if model_list:
                            selected = (selected + 1) % len(model_list)
                            needs_update = True
                    elif key in (KEY_ENTER, KEY_NEWLINE) and detail_model is None:
                        if model_list and 0 <= selected < len(model_list):
                            detail_model = model_list[selected].get("id")
                            needs_update = True

                    # Periodic display refresh (system stats update in background)
                    now = time.time()
                    if now - last_refresh >= args.interval:
                        last_refresh = now
                        needs_update = True

                    if needs_update:
                        display, model_list = build_display(
                            base_url, collector.latest, selected, detail_model,
                        )
                        if model_list:
                            selected = min(selected, len(model_list) - 1)
                        live.update(display)

        except KeyboardInterrupt:
            pass
        finally:
            collector.stop()


if __name__ == "__main__":
    main()
